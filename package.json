{
  "name": "@cinatra-ai/reviewer-agent",
  "version": "0.1.1",
  "license": "Apache-2.0",
  "description": "Generic content reviewer — receives a content bundle, LLM-advises the frontend on which renderer to use, then waits for human approval.",
  "type": "module",
  "files": [
    "cinatra",
    "skills"
  ],
  "cinatra": {
    "apiVersion": "cinatra.ai/v1",
    "kind": "agent",
    "dependencies": [],
    "fieldRenderers": [
      {
        "id": "@cinatra-ai/reviewer-agent:contacts-output",
        "kind": "campaign-recipients-review",
        "priority": 80
      },
      {
        "id": "@cinatra-ai/reviewer-agent:drafts-output",
        "kind": "email-drafts-review",
        "priority": 80
      },
      {
        "id": "@cinatra-ai/reviewer-agent:followups-output",
        "kind": "email-drafts-review",
        "priority": 80
      },
      {
        "id": "@cinatra-ai/reviewer-agent:output",
        "kind": "reviewer-output",
        "priority": 80
      }
    ]
  }
}
